[
    {
        // The everyday debug build — the one rocgdb attaches to (-O0 -g).
        // Vardagsbygget — det som rocgdb fäster vid.
        "label": "cmake build (debug)",
        "command": "cmake",
        "args": ["--build", "build/debug", "-j"],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always" // show output in the terminal panel
    },
    {
        // The profiling build — never profile the debug build, the numbers lie.
        // Profileringsbygget — profilera ALDRIG en debug-build, siffrorna ljuger.
        "label": "cmake build (release)",
        "command": "cmake",
        "args": ["--build", "build/release", "-j"],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always"
    },
    {
        // One-time (re)configure if you blew away the build dir or edited the preset.
        // Engångskonfiguration om du raderat build-katalogen eller ändrat preset:en.
        "label": "cmake configure (debug)",
        "command": "cmake",
        "args": ["--preset", "debug"],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always"
    },
    {
        // Run pre-commit checks on staged files (same as git commit).
        // Kör formatering och lint på filer som är staged.
        "label": "pre-commit (staged)",
        "command": "bash",
        "args": ["-c", "source droplet/venv/bin/activate && pre-commit run"],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always"
    },
    {
        // Run pre-commit checks on all files — useful before pushing.
        // Kör formatering och lint på ALLA filer — bra innan push.
        "label": "pre-commit (all files)",
        "command": "bash",
        "args": ["-c", "source droplet/venv/bin/activate && pre-commit run --all-files"],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always"
    },
    {
        // Install pre-commit git hooks (one-time setup).
        // Installerar git-hooks för pre-commit (engångsinställning).
        "label": "pre-commit (install hooks)",
        "command": "bash",
        "args": ["-c", "source droplet/venv/bin/activate && pre-commit install"],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always"
    }
]
