# =============================================================================
# .clangd — språkserverkonfig / language-server config   (ck_tile_course)
# =============================================================================
#
#   DETTA ÄR PROFESSORNS HUVUDFIL. Läs kommentaren innan du kopierar.
#   THIS IS THE PROFESSOR'S KEY FILE. Read the comment before copying.
#
#   PROBLEMET / THE PROBLEM
#     Din fat binary kompileras med TVÅ arkitekturflaggor:
#     Your fat binary compiles with TWO architecture flags:
#         --offload-arch=gfx942 --offload-arch=gfx950
#     clangd är en single-frontend-analysator. Den kan INTE resonera om två
#     arkitekturer samtidigt — MFMA-intrinsics och wavefront-detaljer skiljer
#     sig mellan CDNA3 och CDNA4. Med båda flaggorna väljer clangd tyst en,
#     eller producerar falska diagnostikfel.
#     clangd is a single-frontend analyser. It CANNOT reason about two arches
#     at once — MFMA intrinsics and wavefront details differ between CDNA3 and
#     CDNA4. With both flags clangd silently picks one, or emits false errors.
#
#   LÖSNINGEN / THE SOLUTION:  "bygg fett, analysera magert"
#                              "build fat, analyse lean"
#     Strippa BÅDA --offload-arch ur kompileringskommandot och lägg tillbaka
#     EN — gfx950, din primära VF. Binären byggs fortfarande för båda; bara
#     IntelliSense pinnas till en deterministisk arkitektur.
#     Strip BOTH --offload-arch from the compile command and add back ONE —
#     gfx950, your primary VF. The binary still builds for both; only
#     IntelliSense is pinned to one deterministic arch.
#
#   NÄR DU FELSÖKER FP64 PÅ MI300X / WHEN DEBUGGING FP64 ON MI300X:
#     Byt gfx950 → gfx942 nedan om du vill att IntelliSense ska spegla CDNA3.
#     Swap gfx950 → gfx942 below if you want IntelliSense to mirror CDNA3.
#     (Detta är en personlig växel — överväg en .clangd i en lokal,
#      gitignorerad override om du växlar ofta.)
#     (This is a personal toggle — consider a local, gitignored override if
#      you switch often.)
#
#   PRIORITETSORDNING / PRIORITY ORDER:
#     compile_commands.json (build/dev) > .clangd Add/Remove > clangd-default
# =============================================================================

CompileFlags:
  # Var hittar clangd kompileringsdatabasen? Peka på dev-profilens byggkatalog.
  # Where does clangd find the compile DB? Point at the dev profile's build dir.
  # (CLion genererar build/dev/compile_commands.json när dev-preset konfigureras.)
  # (CLion generates build/dev/compile_commands.json when the dev preset runs.)
  CompilationDatabase: build/dev

  # Lägg till: tvinga HIP-läge och EN arkitektur för analys.
  # Add: force HIP mode and ONE architecture for analysis.
  Add:
    - -xhip
    - --offload-arch=gfx942
    - -std=c++20

  # Ta bort: allt som förvirrar clangd-frontend:en.
  # Remove: everything that confuses the clangd frontend.
  Remove:
    - --offload-arch=*          # strippa BÅDA fat-flaggorna (strip BOTH fat flags)
    - -munsafe-fp-atomics       # codegen-flagga, irrelevant för analys (codegen-only)
    - -mllvm*                   # backend-flaggor clangd inte förstår (backend flags)
    - --save-temps              # I/O-flagga, ingen semantik (I/O flag, no semantics)

Diagnostics:
  # clangd:s egna kataloger i ROCm-headers ger ibland brus. Tysta kända
  # icke-fel utan att dölja äkta problem i DIN kod.
  # clangd's traversal of ROCm headers occasionally produces noise. Silence
  # known non-errors without hiding real problems in YOUR code.
  Suppress:
    - unknown_typename          # __global__ etc. om en flagga missas (if a flag slips)
  UnusedIncludes: Strict        # håll inkluderingarna ärliga (keep includes honest)
