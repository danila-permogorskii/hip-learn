{
  "version": 3,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (gfx942+gfx950, -O0 -g)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_HIP_ARCHITECTURES": "gfx942;gfx950",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (gfx942+gfx950, -O3)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_HIP_ARCHITECTURES": "gfx942;gfx950",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ]
}