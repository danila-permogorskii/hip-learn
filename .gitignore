# HIP.gitignore
# Gitignore for AMD HIP (ROCm) learning repo

# 1. Compilation outputs and intermediates
*.o
*.obj
*.so
*.a
*.d
*.gch
*.ii
*.ii.cpp
*.gcno
*.gcda
*.dwo
*.dwp

# 2. Executables and binaries
*.exe
*.out
# extensionless compiled binaries (matching .hip source stem)
main
sample

# 3. HIP/ROCm specific intermediates
*.hipfb                        # HIP fat binary (clang-offload-bundler)
*.hsaco                        # ROCm compiled GPU binary
*.s                            # assembly output
*.kernels.cpp                  # autogenerated kernel sources
*.hip.cpp.*                    # hipcc intermediate outputs

# 4. Profiling outputs (rocprof / rocprofv3)
*.gsv                          # rocprof trace files
*.sqlite                       # rocprofv3 database
*.csv                          # rocprof --stats CSV output
*.json                         # rocprofv3 JSON output
rocprof*.log                   # rocprof logs

# 5. Build system artifacts
/build/
/CMakeFiles/
CMakeCache.txt
Makefile
cmake_install.cmake
install_manifest.txt
*.ninja-dep
*.ninja_log
meson-logs/

# 6. IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 7. Tags and logs
tags
*.log
/tests_output/
/samples_output/
