# =============================================================================
# .gitignore — ck_tile_course
# =============================================================================
# Regel / Rule:  committa KÄLLA och KONFIG, ignorera ALLT genererat.
#                commit SOURCE and CONFIG, ignore EVERYTHING generated.
# =============================================================================

# Byggkataloger (build dirs) — en per preset: build/dev, build/release, build/debug
build/
cmake-build-*/          # CLion:s standardnamn om du INTE använder presets
                        # CLion's default name if you do NOT use presets

# Kompilator-mellanfiler från --save-temps och *_asm-målen
# Compiler intermediates from --save-temps and the *_asm targets
*.s
*.ll
*.bc
*.tmp
*.o
*.hipfb                 # HIP fat-binary mellanled (intermediate)

# clangd-index (snabbar upp navigering, men ska INTE versionshanteras)
# clangd index (speeds up navigation, but must NOT be versioned)
.cache/
.clangd/                # OBS: filen .clangd committas; KATALOGEN .clangd/ gör inte
                        # NOTE: the FILE .clangd is committed; the DIR .clangd/ is not

# Personliga, icke-delade preset-avvikelser
# Personal, non-shared preset deviations
CMakeUserPresets.json

# CLion personliga inställningar (men .run/ committas — se nedan)
# CLion personal settings (but .run/ IS committed — see below)
.idea/
!.idea/                 # om du vill dela vissa .idea-filer, ta bort denna rad
                        # if you want to share some .idea files, drop this line

# rocprofv3 / rocprof-compute utdata
# rocprofv3 / rocprof-compute output
*.csv
results.json
out/
pftrace/
